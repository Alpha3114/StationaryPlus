# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Local development database (defaults below match a stock XAMPP install)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=stationaryplus

# Production database — used by db_server.php on deploy
PROD_DB_HOST=localhost
PROD_DB_USER=
PROD_DB_PASS=
PROD_DB_NAME=

# Gemini API (https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Outgoing mail (Gmail App Password: https://myaccount.google.com/apppasswords)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
